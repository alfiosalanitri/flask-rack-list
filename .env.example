# Copy this file to .env and fill in your values before running with Docker Compose.
# .env is gitignored — never commit real credentials.

# Admin credentials for the /admin area
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Flask secret key — used to sign session cookies.
# Generate one with: docker run --rm ghcr.io/alfiosalanitri/docker-fernet-key-generator:latest
SECRET_KEY=change-this-to-a-long-random-string
